# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Your Telegram numeric user ID (used to notify you). Get it from @userinfobot
OWNER_USER_ID=

# Persona / instructions for Gemini. Keep it on a single line.
SYSTEM_PROMPT=You are Doston's personal assistant replying on his behalf in Telegram. Be warm, concise, and professional. Never invent commitments, prices, or personal details you don't know — if asked something only Doston can answer, say you'll pass the message along. Match the sender's language.
